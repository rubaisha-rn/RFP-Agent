# ─── Supabase ──────────────────────────────────────────────
# Project URL and keys from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ─── Google Gemini (via Google AI Studio / GCP) ────────────
# API key used by all 4 ADK agents
GOOGLE_API_KEY=your-gemini-api-key

# ─── App ───────────────────────────────────────────────────
# Secret used for app-level signing / sessions
APP_SECRET=change-me-to-a-long-random-string

# Model selection (all default to gemini-2.5-flash if omitted)
GEMINI_MODEL=gemini-2.5-flash

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ─── Resend (transactional email) ──────────────────────────
# API key from resend.com → API Keys
RESEND_API_KEY=your-resend-api-key
# Verified sender. Defaults to onboarding@resend.dev if omitted.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── Demo email redirect ───────────────────────────────────
# When set, ALL outgoing vendor emails are redirected to this single
# verified inbox (the original recipient is preserved in the subject
# line and the sent_emails audit trail). Leave BLANK in production so
# emails go to real vendor addresses.
DEMO_REDIRECT_ALL_EMAILS_TO=your-verified-inbox@example.com
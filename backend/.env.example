# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini (via Google AI Studio)
# Free tier daily quota is small; set up paid Tier 1 for stable demos.
GOOGLE_API_KEY=your-google-ai-studio-key-here

# App secret for any session/JWT signing (any random 32+ char string)
APP_SECRET=replace-with-a-random-32-character-string

# Gemini model selection. gemini-2.5-flash is the default.
GEMINI_MODEL=gemini-2.5-flash

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Resend (real email delivery). Optional — if omitted, emails are simulated
# (still persisted to Supabase). Get a free key at https://resend.com.
# Free tier only sends from onboarding@resend.dev unless you verify a domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=RFP Agent System